/ {
    /* led on pin 23 that is connectet to a thriac via a optocoupler */
    leds {
        compatible = "gpio-leds";
        led_moc: led_moc {
            gpios = <&gpio0 23 GPIO_ACTIVE_HIGH>;
            label = "MOC Triac Control";
        };
    };

    /* Alias for the led */
    aliases {
        app-led = &led_moc;
    };
};